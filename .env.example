# Root
NODE_ENV=

# API server
PORT=8080
API_HOST=
FRONTEND_URL=
LOG_LEVEL=
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=
AUTH_RATE_LIMIT_MAX=

# MongoDB
MONGODB_URI=

# JWT (RSA keys for RS256; use long PEM/base64 strings locally, store in SSM for production)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES=
JWT_REFRESH_EXPIRES=

# AWS base config
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SSM_PREFIX=

# AWS S3 (leave AWS keys empty in production; use the EC2 IAM role)
S3_BUCKET_NAME=caresync-files-prod
S3_PRESIGN_EXPIRES=900

# AWS SQS
SQS_WHATSAPP_QUEUE_URL=
SQS_SMS_QUEUE_URL=
SQS_PDF_QUEUE_URL=
SQS_REPORT_QUEUE_URL=

# AWS SES
SES_FROM_EMAIL=

# WhatsApp Business
WABA_PHONE_ID=
WABA_ACCESS_TOKEN=

# SMS
SMS_API_KEY=
SMS_SENDER_ID=

# ABDM
ABDM_BASE_URL=
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=

# Encryption (32-byte hex = 64 chars)
ENCRYPTION_KEY=

# Optional CloudWatch logging
CLOUDWATCH_LOG_GROUP=
CLOUDWATCH_LOG_STREAM=

# Web
WEB_PORT=
VITE_API_BASE_URL=

# Infra / deployment
NGINX_PORT=
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PATH=
